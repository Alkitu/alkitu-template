{
  "name": "@alkitu/template",
  "version": "1.0.0",
  "private": true,
  "description": "Alkitu Template - Complete Fullstack Monorepo with Web, API, and Mobile applications",
  "keywords": [
    "alkitu",
    "template",
    "monorepo",
    "nextjs",
    "nestjs",
    "flutter",
    "fullstack"
  ],
  "author": "Alkitu Team",
  "license": "MIT",
  "scripts": {
    "prepare": "git submodule update --init --recursive || true",
    "dev": "npm-run-all --parallel dev:web dev:api",
    "dev:web": "pnpm --filter @alkitu/web run dev",
    "dev:api": "pnpm --filter @alkitu/api run dev",
    "dev:docker": "docker-compose -f docker-compose.dev.yml up -d",
    "build": "pnpm run build:shared && pnpm run build:api && pnpm run build:web",
    "build:shared": "pnpm --filter @alkitu/shared run build",
    "build:api": "pnpm --filter @alkitu/api run build",
    "build:web": "pnpm --filter @alkitu/web run build",
    "test": "pnpm run test:web && pnpm run test:api && pnpm run test:shared",
    "test:unit": "pnpm run test:web && pnpm run test:api && pnpm run test:shared",
    "test:all": "pnpm run lint && pnpm run type-check && pnpm run test",
    "test:web": "pnpm --filter @alkitu/web run test",
    "test:api": "pnpm --filter @alkitu/api run test",
    "test:shared": "pnpm --filter @alkitu/shared run test",
    "test:mutation": "pnpm --filter @alkitu/api run test:mutation || echo 'Mutation testing not configured yet'",
    "test:e2e": "pnpm --filter @alkitu/web run test:e2e",
    "test:e2e:ui": "pnpm --filter @alkitu/web run test:e2e:ui",
    "test:e2e:debug": "pnpm --filter @alkitu/web run test:e2e:debug",
    "test:e2e:ali-116": "pnpm --filter @alkitu/web run test:e2e:ali-116",
    "test:playwright": "pnpm --filter @alkitu/web run test:playwright",
    "quality:gates": "pnpm run lint && pnpm run type-check && pnpm run test",
    "lint": "pnpm run lint:web && pnpm run lint:api && pnpm run lint:shared",
    "lint:web": "pnpm --filter @alkitu/web run lint",
    "lint:api": "pnpm --filter @alkitu/api run lint",
    "lint:shared": "pnpm --filter @alkitu/shared run lint",
    "type-check": "pnpm run type-check:web && pnpm run type-check:api && pnpm run type-check:shared",
    "type-check:web": "pnpm --filter @alkitu/web run type-check",
    "type-check:api": "pnpm --filter @alkitu/api run type-check",
    "type-check:shared": "pnpm --filter @alkitu/shared run type-check",
    "clean": "pnpm run clean:web && pnpm run clean:api && pnpm run clean:shared && rm -rf dist",
    "clean:web": "pnpm --filter @alkitu/web run clean",
    "clean:api": "pnpm --filter @alkitu/api run clean",
    "clean:shared": "pnpm --filter @alkitu/shared run clean",
    "docker:stop": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:restart": "docker-compose -f docker-compose.dev.yml restart",
    "db:shell": "docker exec -it alkitu-mongodb-dev mongosh",
    "db:migrate": "cd packages/api && pnpm run prisma:migrate",
    "db:push": "cd packages/api && pnpm run prisma:push",
    "db:studio": "cd packages/api && pnpm run prisma:studio",
    "db:test": "node scripts/test-db-connection.js",
    "create:screenshot-users": "ts-node -P packages/api/tsconfig.json scripts/create-screenshot-users.ts",
    "delete:screenshot-users": "ts-node -P packages/api/tsconfig.json scripts/delete-screenshot-users.ts",
    "create:screenshot-data": "ts-node -P packages/api/tsconfig.json scripts/create-screenshot-data.ts",
    "delete:screenshot-data": "ts-node -P packages/api/tsconfig.json scripts/delete-screenshot-data.ts",
    "create:screenshot-services": "ts-node -P packages/api/tsconfig.json scripts/create-screenshot-services.ts",
    "delete:screenshot-services": "ts-node -P packages/api/tsconfig.json scripts/delete-screenshot-services.ts",
    "create:screenshot-requests": "ts-node -P packages/api/tsconfig.json scripts/create-screenshot-requests.ts",
    "delete:screenshot-requests": "ts-node -P packages/api/tsconfig.json scripts/delete-screenshot-requests.ts",
    "screenshots:capture": "ts-node -P packages/api/tsconfig.json scripts/capture-screenshots.ts",
    "screenshots:upload": "ts-node -P packages/api/tsconfig.json scripts/upload-to-cloudinary.ts"
  },
  "devDependencies": {
    "@types/culori": "^4.0.0",
    "@types/node": "^20.0.0",
    "baseline-browser-mapping": "^2.8.32",
    "concurrently": "^8.2.2",
    "npm-run-all": "^4.1.5",
    "prisma": "^6.19.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/alkitu-template.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/alkitu-template/issues"
  },
  "homepage": "https://github.com/your-org/alkitu-template#readme",
  "pnpm": {
    "overrides": {
      "elliptic": ">=6.6.1",
      "js-yaml": ">=4.1.1",
      "lodash": ">=4.17.23",
      "tar": ">=7.5.7",
      "webpack": ">=5.105.0"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "culori": "^4.0.2",
    "mongodb": "^6.20.0",
    "react-textarea-autosize": "^8.5.9",
    "zustand": "^5.0.6"
  }
}
